# Copy this file to key.properties and fill in your release keystore values.
# key.properties is gitignored — never commit it or your .jks keystore.
#
# Generate a keystore (one-time):
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# Place the keystore under android/ (or adjust storeFile path below).

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=upload
storeFile=upload-keystore.jks
